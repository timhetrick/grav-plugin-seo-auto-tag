{# SEO Auto-Tag Logic #}

{# ── Plugin Config ── #}
{% set seo_config = config.plugins['seo-auto-tag'] %}

{# 1. Title Logic #}
{% set seo_title = page.header.seo.title|default(page.title) %}
{% if seo_config.append_site_name %}
    {% set separator = seo_config.title_separator|default(' | ') %}
    {% set seo_title = seo_title ~ separator ~ site.title %}
{% endif %}

{# 2. Description Fallback Logic #}
{% set seo_desc = page.header.seo.description %}
{% if not seo_desc %}
    {% set seo_desc = page.metadata['description'] %}
{% endif %}
{% if not seo_desc %}
    {% set seo_desc = page.content()|striptags|truncate(155, false)|replace({"\\r": "", "\\n": " "})|trim %}
{% endif %}

{# 3. Image Fallback Logic — normalize to absolute URL once #}
{% set seo_image = null %}
{% if page.header.seo.image %}
    {% set seo_image = url(page.header.seo.image, true) %}
{% else %}
    {% set first_image = page.media.images|first %}
    {% if first_image %}
        {% set seo_image = first_image.url(true) %}
    {% endif %}
{% endif %}

{% if not seo_image %}
    {% set default_brand_image = seo_config.default_brand_image %}
    {% if default_brand_image %}
        {% set seo_image = url(default_brand_image, true) %}
    {% endif %}
{% endif %}

{# 4. Robots #}
{% set seo_robots = page.header.seo.robots|default('') %}

{# ── Output Tags ── #}

{# Canonical #}
<link rel="canonical" href="{{ page.url(true) }}">

{# Basic Meta #}
{% if seo_desc %}
<meta name="description" content="{{ seo_desc|e('html_attr') }}">
{% endif %}

{% if seo_robots %}
<meta name="robots" content="{{ seo_robots|e('html_attr') }}">
{% endif %}

{# OpenGraph #}
<meta property="og:title" content="{{ seo_title|e('html_attr') }}">
{% if seo_desc %}
<meta property="og:description" content="{{ seo_desc|e('html_attr') }}">
{% endif %}
<meta property="og:type" content="{{ page.home ? 'website' : 'article' }}">
<meta property="og:url" content="{{ page.url(true) }}">
<meta property="og:site_name" content="{{ site.title|e('html_attr') }}">
<meta property="og:locale" content="{{ grav.language.getActive|default('en') }}">
{% if seo_image %}
<meta property="og:image" content="{{ seo_image }}">
{% endif %}

{# Twitter Card #}
<meta name="twitter:card" content="{{ seo_image ? 'summary_large_image' : 'summary' }}">
<meta name="twitter:title" content="{{ seo_title|e('html_attr') }}">
{% if seo_desc %}
<meta name="twitter:description" content="{{ seo_desc|e('html_attr') }}">
{% endif %}
{% if seo_image %}
<meta name="twitter:image" content="{{ seo_image }}">
{% endif %}

{# JSON-LD Structured Data #}
{% if seo_config.json_ld %}
{% set schema_type = page.home ? 'WebPage' : 'Article' %}
{% set json_ld = {
    '@context': 'https://schema.org',
    '@type': schema_type,
    'name': seo_title,
    'headline': seo_title,
    'url': page.url(true)
} %}
{% if seo_desc %}
    {% set json_ld = json_ld|merge({ 'description': seo_desc }) %}
{% endif %}
{% if seo_image %}
    {% set json_ld = json_ld|merge({ 'image': seo_image }) %}
{% endif %}
{% if page.date %}
    {% set json_ld = json_ld|merge({ 'datePublished': page.date|date('c') }) %}
{% endif %}
{% if page.header.modified %}
    {% set json_ld = json_ld|merge({ 'dateModified': page.header.modified|date('c') }) %}
{% endif %}
{% set json_ld = json_ld|merge({
    'publisher': {
        '@type': 'Organization',
        'name': site.title
    },
    'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': page.url(true)
    }
}) %}
<script type="application/ld+json">
{{ json_ld|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
</script>
{% endif %}
